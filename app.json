{
  "expo": {
    "name": "Civic Citizenship",
    "slug": "civic-citizenship",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "description": "Learn civics through interactive quizzes and voice interviews. Master American civics with adaptive learning, real-time feedback, and personalized study paths.",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.civiceducation.citizenship",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "We need microphone access to record your civics interview responses. Audio is processed locally and not stored permanently.",
        "NSLocationWhenInUseUsageDescription": "Location is not used by this app.",
        "UIRequiredDeviceCapabilities": [
          "microphone",
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.civiceducation.citizenship",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-sharing",
      "expo-font"
    ],
    "scheme": "civiceducation",
    "owner": "aharel",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "enabled": true,
      "url": "https://updates.expo.dev/civiceducation/civic-citizenship"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "sdkVersion": "55.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "9d8a4235-35c2-49d5-b14c-3aaab53de7c9"
      }
    }
  }
}
